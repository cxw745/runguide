---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="关于我们">
  <Header />
  <main class="about-page">
    <div class="container">
      <div class="about-hero">
        <h1 class="about-title">📖 关于广财飞跃手册</h1>
        <p class="about-subtitle">由广财学子自发维护的真实经验分享平台</p>
      </div>

      <div class="about-section">
        <h2 class="about-section-title">我们是谁</h2>
        <div class="about-card">
          <p>广财飞跃手册是一个由广东财经大学在校学生和校友自发组建、维护的开放经验分享平台。我们相信：<strong>消除信息差，是帮助每一位广财人在关键节点做出更清晰选择的最有效方式。</strong></p>
          <p>这里没有官方宣传，没有机构营销——只有和你一样的广财人，写下的真实故事。</p>
        </div>
      </div>

      <div class="about-section">
        <h2 class="about-section-title">我们的使命</h2>
        <div class="mission-grid">
          <div class="mission-card">
            <span class="mission-icon">🎯</span>
            <h3>消除信息差</h3>
            <p>让每一位广财人都能获取到真实、有用的学业规划信息</p>
          </div>
          <div class="mission-card">
            <span class="mission-icon">🤝</span>
            <h3>经验传承</h3>
            <p>学长学姐走过的路、踩过的坑，就是后来者最好的参考</p>
          </div>
          <div class="mission-card">
            <span class="mission-icon">🌱</span>
            <h3>共建互助</h3>
            <p>每个人都可以贡献自己的经验，让社区持续成长</p>
          </div>
        </div>
      </div>

      <div class="about-section">
        <h2 class="about-section-title">覆盖方向</h2>
        <div class="directions-list">
          <div class="direction-item">
            <span class="direction-icon">🔄</span>
            <div>
              <h3>转专业</h3>
              <p>跨院系转专业经验、面试准备、学分转换指南</p>
            </div>
          </div>
          <div class="direction-item">
            <span class="direction-icon">🎓</span>
            <div>
              <h3>保研</h3>
              <p>推免资格、夏令营、材料准备全流程</p>
            </div>
          </div>
          <div class="direction-item">
            <span class="direction-icon">📚</span>
            <div>
              <h3>考研</h3>
              <p>院校选择、备考规划、复试调剂经验</p>
            </div>
          </div>
          <div class="direction-item">
            <span class="direction-icon">✈️</span>
            <div>
              <h3>出国留学</h3>
              <p>选校定位、语言考试、文书写作、申请时间线</p>
            </div>
          </div>
          <div class="direction-item">
            <span class="direction-icon">💼</span>
            <div>
              <h3>就业</h3>
              <p>校招准备、实习经验、面试技巧、行业选择</p>
            </div>
          </div>
          <div class="direction-item">
            <span class="direction-icon">💡</span>
            <div>
              <h3>其他</h3>
              <p>大学生活规划、竞赛经验、考证指南等</p>
            </div>
          </div>
        </div>
      </div>

      <div class="about-section">
        <h2 class="about-section-title">开源与贡献</h2>
        <div class="about-card">
          <p>广财飞跃手册是一个完全开源的项目，代码托管在 GitHub 上。我们欢迎所有广财人参与贡献——无论是投稿经验文章、改进网站功能，还是修复一个错别字，每一份贡献都有价值。</p>
          <div class="about-links">
            <a href="https://github.com/cxw745/runaway745" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
              ⭐ GitHub 仓库
            </a>
            <a href="/submit" class="btn btn-secondary">
              📝 投稿分享
            </a>
          </div>
        </div>
      </div>

      <div class="about-section">
        <h2 class="about-section-title">数据与影响力</h2>
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-num">10万+</span>
            <span class="stat-label">累计阅读量</span>
          </div>
          <div class="stat-card">
            <span class="stat-num">50+</span>
            <span class="stat-label">真实经验文章</span>
          </div>
          <div class="stat-card">
            <span class="stat-num">6</span>
            <span class="stat-label">覆盖方向</span>
          </div>
          <div class="stat-card">
            <span class="stat-num">开源</span>
            <span class="stat-label">完全开放源码</span>
          </div>
        </div>
      </div>

      <div class="about-section">
        <h2 class="about-section-title">免责声明</h2>
        <div class="about-card disclaimer">
          <p>本平台所有文章内容仅代表作者个人观点和经验，不构成任何官方建议。每位同学的情况不同，请结合自身实际做出判断和选择。本平台不对任何因参考文章内容而产生的后果承担责任。</p>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .about-page {
    padding: 48px 0 64px;
    min-height: 60vh;
  }

  .about-hero {
    text-align: center;
    margin-bottom: 56px;
  }

  .about-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: 12px;
  }

  .about-subtitle {
    font-size: 16px;
    color: var(--text-secondary);
  }

  .about-section {
    max-width: 720px;
    margin: 0 auto 48px;
  }

  .about-section-title {
    font-size: 22px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--accent);
    display: inline-block;
  }

  .about-card {
    padding: 28px 32px;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }

  .about-card p {
    font-size: 15px;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 12px;
  }

  .about-card p:last-child {
    margin-bottom: 0;
  }

  .about-card strong {
    color: var(--text-primary);
  }

  .about-links {
    display: flex;
    gap: 12px;
    margin-top: 20px;
  }

  .mission-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .mission-card {
    padding: 24px 20px;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .mission-icon {
    font-size: 32px;
    display: block;
    margin-bottom: 12px;
  }

  .mission-card h3 {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .mission-card p {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .directions-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .direction-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 16px 20px;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }

  .direction-icon {
    font-size: 24px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .direction-item h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .direction-item p {
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .stat-card {
    padding: 24px 16px;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .stat-num {
    display: block;
    font-size: 24px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 6px;
  }

  .stat-label {
    font-size: 13px;
    color: var(--text-secondary);
  }

  .disclaimer {
    background-color: var(--accent-light);
    border-color: transparent;
  }

  @media (max-width: 720px) {
    .mission-grid {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .about-links {
      flex-direction: column;
    }
  }
</style>
