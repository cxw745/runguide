---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const currentIndex = sortedArticles.findIndex(a => a.id === article.id);
const prevArticle = currentIndex > 0 ? sortedArticles[currentIndex - 1] : null;
const nextArticle = currentIndex < sortedArticles.length - 1 ? sortedArticles[currentIndex + 1] : null;
---

<BaseLayout title={article.data.title} description={article.data.excerpt}>
  <Header />
  <main class="article-page">
    <div class="container">
      <article class="article-detail">
        <header class="article-header">
          <a href="/articles" class="article-back">← 返回文章列表</a>
          <div class="article-meta">
            <span class="tag">{article.data.category}</span>
            <span class="article-meta-item">{article.data.date}</span>
            <span class="article-meta-item">✍️ {article.data.author}</span>
          </div>
          <h1 class="article-title">{article.data.title}</h1>
          {article.data.tags.length > 0 && (
            <div class="article-tags">
              {article.data.tags.map((tag: string) => (
                <span class="article-tag">{tag}</span>
              ))}
            </div>
          )}
        </header>
        <div class="prose">
          <Content />
        </div>
        <footer class="article-nav">
          {prevArticle ? (
            <a href={`/articles/${prevArticle.id}`} class="article-nav-link article-nav-prev">
              <span class="article-nav-label">← 上一篇</span>
              <span class="article-nav-title">{prevArticle.data.title}</span>
            </a>
          ) : <div></div>}
          {nextArticle ? (
            <a href={`/articles/${nextArticle.id}`} class="article-nav-link article-nav-next">
              <span class="article-nav-label">下一篇 →</span>
              <span class="article-nav-title">{nextArticle.data.title}</span>
            </a>
          ) : <div></div>}
        </footer>
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .article-page {
    padding: 48px 0 64px;
    min-height: 60vh;
  }

  .article-detail {
    max-width: 760px;
    margin: 0 auto;
  }

  .article-back {
    display: inline-flex;
    align-items: center;
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 24px;
    transition: color 0.2s;
  }

  .article-back:hover {
    color: var(--accent);
    opacity: 1;
  }

  .article-header {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .article-meta-item {
    font-size: 13px;
    color: var(--text-muted);
  }

  .article-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: 16px;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .article-tag {
    font-size: 12px;
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    background-color: var(--accent-light);
    color: var(--accent);
  }

  .article-nav {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  .article-nav-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 20px;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: all 0.2s;
    max-width: 45%;
  }

  .article-nav-link:hover {
    border-color: var(--accent);
    opacity: 1;
  }

  .article-nav-next {
    text-align: right;
    margin-left: auto;
  }

  .article-nav-label {
    font-size: 12px;
    color: var(--text-muted);
  }

  .article-nav-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 480px) {
    .article-title {
      font-size: 24px;
    }

    .article-nav {
      flex-direction: column;
    }

    .article-nav-link {
      max-width: 100%;
    }

    .article-nav-next {
      text-align: left;
      margin-left: 0;
    }
  }
</style>
