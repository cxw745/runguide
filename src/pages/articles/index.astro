---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = ['全部', '转专业', '保研', '考研', '出国留学', '就业', '其他'];
---

<BaseLayout title="文章">
  <Header />
  <main class="articles-page">
    <div class="container">
      <div class="articles-page-header">
        <h1 class="articles-page-title">全部文章</h1>
        <p class="articles-page-desc">学长学姐的真实经验分享，总有一篇能帮到你</p>
      </div>
      <div class="articles-filters" id="articles-filters">
        {categories.map(cat => (
          <button
            class:list={['filter-chip', { active: cat === '全部' }]}
            data-category={cat === '全部' ? '' : cat}
          >
            {cat}
          </button>
        ))}
      </div>
      <div class="article-list" id="article-list">
        {sortedArticles.map(article => (
          <a href={`/articles/${article.id}`} class="article-list-item" data-category={article.data.category}>
            <div class="article-list-body">
              <h3 class="article-list-title">{article.data.title}</h3>
              <p class="article-list-excerpt">{article.data.excerpt}</p>
            </div>
            <div class="article-list-meta">
              <span class="tag article-list-tag">{article.data.category}</span>
              <span class="article-list-author">✍️ {article.data.author}</span>
              <span class="article-list-date">{article.data.date}</span>
            </div>
          </a>
        ))}
      </div>
      <div class="articles-empty" id="articles-empty" style="display:none;">
        <p>该分类暂无文章</p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const categoryParam = params.get('category');

  const chips = document.querySelectorAll('.filter-chip');
  const items = document.querySelectorAll('.article-list-item');
  const empty = document.getElementById('articles-empty');

  function filterArticles(category) {
    chips.forEach(chip => {
      const chipCat = chip.getAttribute('data-category') || '';
      chip.classList.toggle('active', chipCat === category);
    });

    let visibleCount = 0;
    items.forEach(item => {
      const itemCat = item.getAttribute('data-category') || '';
      const show = !category || itemCat === category;
      (item as HTMLElement).style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });

    empty.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  if (categoryParam) {
    filterArticles(categoryParam);
  }

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      const category = chip.getAttribute('data-category') || '';
      filterArticles(category);
      const url = new URL(window.location.href);
      if (category) {
        url.searchParams.set('category', category);
      } else {
        url.searchParams.delete('category');
      }
      history.replaceState(null, '', url.toString());
    });
  });
</script>

<style>
  .articles-page {
    padding: 48px 0 64px;
    min-height: 60vh;
  }

  .articles-page-header {
    margin-bottom: 32px;
  }

  .articles-page-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .articles-page-desc {
    font-size: 16px;
    color: var(--text-secondary);
  }

  .articles-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }

  .filter-chip {
    padding: 6px 16px;
    font-family: var(--font-stack);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-chip:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .filter-chip.active {
    background-color: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .article-list {
    display: flex;
    flex-direction: column;
  }

  .article-list-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 20px 24px;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: all 0.2s ease;
    text-decoration: none;
    margin-bottom: 8px;
  }

  .article-list-item:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-hover);
    opacity: 1;
    transform: translateX(4px);
  }

  .article-list-body {
    flex: 1;
    min-width: 0;
  }

  .article-list-title {
    font-size: 17px;
    font-weight: 600;
    line-height: 1.35;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .article-list-excerpt {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-list-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .article-list-tag {
    white-space: nowrap;
  }

  .article-list-author,
  .article-list-date {
    font-size: 12px;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .articles-empty {
    text-align: center;
    padding: 64px 0;
    color: var(--text-muted);
    font-size: 15px;
  }

  @media (max-width: 720px) {
    .article-list-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .article-list-meta {
      flex-wrap: wrap;
    }
  }
</style>
