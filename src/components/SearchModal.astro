---
const { articles } = Astro.props;
---

<div class="search-container" id="search-container">
  <div class="search-overlay" id="search-overlay"></div>
  <div class="search-modal" id="search-modal">
    <div class="search-header">
      <span class="search-icon">🔍</span>
      <input
        type="text"
        id="search-input"
        placeholder="搜索文章标题、内容、标签..."
        autocomplete="off"
        autofocus
      />
      <kbd>ESC</kbd>
    </div>
    <div class="search-results" id="search-results">
      <div class="search-hint">输入关键词开始搜索</div>
    </div>
  </div>
</div>

<script define:vars={{ articles }}>
  const container = document.getElementById('search-container');
  const overlay = document.getElementById('search-overlay');
  var inputEl = document.getElementById('search-input');
  const results = document.getElementById('search-results');

  function openSearch() {
    if (!container || !inputEl || !results) return;
    container.classList.add('open');
    document.body.style.overflow = 'hidden';
    setTimeout(function() { if (inputEl) inputEl.focus(); }, 100);
  }

  function closeSearch() {
    if (!container || !inputEl || !results) return;
    container.classList.remove('open');
    document.body.style.overflow = '';
    inputEl.value = '';
    results.innerHTML = '<div class="search-hint">输入关键词开始搜索</div>';
  }

  overlay.addEventListener('click', closeSearch);

  document.addEventListener('keydown', function(e) {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape' && container && container.classList.contains('open')) {
      closeSearch();
    }
  });

  inputEl.addEventListener('input', function() {
    var query = inputEl.value.trim().toLowerCase();
    if (!query) {
      results.innerHTML = '<div class="search-hint">输入关键词开始搜索</div>';
      return;
    }

    var matched = articles.filter(function(a) {
      return a.title.toLowerCase().indexOf(query) !== -1 ||
             a.excerpt.toLowerCase().indexOf(query) !== -1 ||
             a.category.toLowerCase().indexOf(query) !== -1 ||
             (a.tags || []).some(function(t) { return t.toLowerCase().indexOf(query) !== -1; }) ||
             a.author.toLowerCase().indexOf(query) !== -1;
    });

    if (matched.length === 0) {
      results.innerHTML = '<div class="search-empty">未找到与 "' + inputEl.value + '" 相关的文章</div>';
      return;
    }

    results.innerHTML = matched.map(function(a) {
      return '<a href="/articles/' + a.id + '" class="search-result-item" onclick="closeSearch()">' +
        '<div class="result-body">' +
          '<h4 class="result-title">' + highlight(a.title, query) + '</h4>' +
          '<p class="result-excerpt">' + highlight(a.excerpt, query) + '</p>' +
        '</div>' +
        '<span class="tag result-tag">' + a.category + '</span>' +
      '</a>';
    }).join('');
  });

  function highlight(text, q) {
    if (!q) return text;
    var escaped = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    var re = new RegExp('(' + escaped + ')', 'gi');
    return text.replace(re, '<mark>$1</mark>');
  }

  window.openSearch = openSearch;
  window.closeSearch = closeSearch;
</script>

<style>
  .search-container {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
  }

  .search-container.open {
    display: block;
  }

  .search-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    animation: fadeIn 0.2s ease;
  }

  .search-modal {
    position: relative;
    max-width: 640px;
    margin: 15vh auto 0;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-hover), 0 24px 80px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    animation: slideDown 0.25s ease;
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
  }

  .search-icon {
    font-size: 18px;
    flex-shrink: 0;
  }

  #search-input {
    flex: 1;
    font-family: var(--font-stack);
    font-size: 16px;
    color: var(--text-primary);
    background: none;
    border: none;
    outline: none;
  }

  #search-input::placeholder {
    color: var(--text-muted);
  }

  kbd {
    padding: 3px 8px;
    font-size: 11px;
    color: var(--text-muted);
    background-color: var(--accent-light);
    border-radius: 4px;
    flex-shrink: 0;
  }

  .search-results {
    max-height: 50vh;
    overflow-y: auto;
    padding: 8px;
  }

  .search-hint,
  .search-empty {
    padding: 32px 16px;
    text-align: center;
    font-size: 14px;
    color: var(--text-muted);
  }

  .search-result-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    transition: background-color 0.15s;
    text-decoration: none;
    margin-bottom: 2px;
  }

  .search-result-item:hover {
    background-color: var(--accent-light);
    opacity: 1;
  }

  .result-body {
    flex: 1;
    min-width: 0;
  }

  .result-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.35;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .result-excerpt {
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(mark) {
    background-color: var(--accent);
    color: #fff;
    padding: 0 2px;
    border-radius: 2px;
  }

  .result-tag {
    white-space: nowrap;
    flex-shrink: 0;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
