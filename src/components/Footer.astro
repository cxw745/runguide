      </div>
      <div class="footer-links">
        <div class="footer-col">
          <h4 class="footer-col-title">分类</h4>
          <a href="/articles?category=转专业">转专业</a>
          <a href="/articles?category=保研">保研</a>
          <a href="/articles?category=考研">考研</a>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">更多</h4>
          <a href="/articles?category=出国留学">出国留学</a>
          <a href="/articles?category=就业">就业</a>
          <a href="/articles?category=其他">其他</a>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">社区</h4>
          <a href="#">投稿指南</a>
          <a href="#">关于我们</a>
          <a href="#">GitHub</a>
        </div>
      </div>
